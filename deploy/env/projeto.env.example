# =============================================================
# Variaveis de ambiente - producao SGPS
# =============================================================
# Copie para a raiz do projeto como .env
#   cp deploy/env/projeto.env.example .env
#   nano .env
#
# Gerar DJANGO_SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# =============================================================

# --- Django ---
DJANGO_SECRET_KEY=COLE_A_CHAVE_GERADA_AQUI
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=sgps.sistema9.com.br,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://sgps.sistema9.com.br

# Mantenha essa chave se ja houver dados criptografados gerados localmente.
DJANGO_FIELD_ENCRYPTION_KEY=tv25H_VMhZdlmABbz7pnncprSwdwQ4CXw2H1mlGEiPQ=

# --- Banco de dados (PostgreSQL) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=sgps
DB_USER=sgps
DB_PASSWORD=troque-por-uma-senha-forte
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Seguranca ---
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
